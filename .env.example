# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/k8s_monitor

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production

# Ansible
ANSIBLE_PLAYBOOK_DIR=/app/ansible/playbooks
ANSIBLE_INVENTORY_DIR=/app/ansible/inventory

# Health Check
CHECK_INTERVAL_MINUTES=5
CHECK_TIMEOUT_SECONDS=30

# Ollama (AI Agent)
# 폐쇄망에서 이미지에 모델을 bake-in한 경우, 실제 pull된 모델명으로 설정
# 예) qwen2.5:7b 이미지를 사용하는 경우:
#   OLLAMA_URL=http://ollama:11434
#   OLLAMA_MODEL=qwen2.5:7b
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=120

# Debug
DEBUG=false
