# 이 파일은 템플릿입니다. 실제 배포 전에 다음 값을 채워 secret.yaml 로 복사하세요.
#
#   cp secret.yaml.tmpl secret.yaml
#   # secret.yaml 의 INGEST_URL / INGEST_TOKEN / CLUSTER_ID 를 교체
#   kubectl apply -k .
#
# (secret.yaml 은 .gitignore 처리 권장)
apiVersion: v1
kind: Secret
metadata:
  name: superpod-agent-config
  namespace: k8s-monitor-agent
type: Opaque
stringData:
  # 관리 backend 의 ingest endpoint (예: https://k8s-monitor.example.com/api/v1/deep-check/ingest)
  SUPERPOD_INGEST_URL: "https://REPLACE-WITH-MANAGEMENT-BACKEND/api/v1/deep-check/ingest"
  # 관리 backend Helm values 의 deepcheck.ingestToken 과 동일해야 함
  SUPERPOD_INGEST_TOKEN: "REPLACE-WITH-INGEST-TOKEN"
  # 관리 backend 에 등록된 이 클러스터의 UUID
  SUPERPOD_CLUSTER_ID: "REPLACE-WITH-CLUSTER-UUID"
